{
  "name": "AnchorFND",
  "ZERO": 1e-8,
  "seed": 42,
  "alpha1": 0.9,
  "alpha2": 0.1,
  "gamma": 1.0,
  "save_freq": 5,
  "cache_path": "../Tagme/archo_cache",
  "train_data_file": "./output_QID_train.json",
  "val_data_file": "./output_QID_val.json",
  "test_data_file": "./output_QID_test.json",
  "datapath": "./WikidataKG/Wikidata/",
  "entity2id_file": "kg/entity2id.txt",
  "relation2id_file": "kg/relation2id.txt",
  "verbosity": 2,
  "kg_file": "./combined.tsv",
  "news_entity_num": 20,
  "node_feature_size": 512,
  "gradient_accumulation_steps": 2,
  "n_gpu": 1,
  "entity_embedding_size": 100,
  "entity_embedding_file": "embeddings/dimension_100/transe/entity2vec.bin",
  "relation_embedding_file": "embeddings/dimension_100/transe/relation2vec.bin",
  "doc_feature_entity_file": "./doc_feature_entity.tsv",
  "doc_embedding_size": 768,
  "embedding_size": 128,
  "max_depth": 3,
  "dropout": 0.5,
  "graph_type": "epsilonNN",
  "graph_metric_type": "weighted_cosine",
  "Graph_learning_layers": 2,
  "Thresholdpool": 0.2,
  "Thresholdsim": 0.25,
  "epsilon": 0.6,
  "num_per": 16,
  "temperature": 0.1,
  "topk": [
    5,
    3,
    2
  ],
  "top_k": 10,
  "graph_skip_conn": 0.0,
  "graph_include_self": true,
  "feature_denoise": true,
  "save_dir": "./out/saved/",
  "lr": 2e-5,
  "lr_anchor": 1e-4,
  "weight_decay": 1e-6,
  "epochs": 100,
  "batch_size": 64,
  "early_stop": 10,
  "root_dir": "",
  "amg_train_json_name": "Split_output_QID_train.json",
  "amg_test_json_name": "Split_output_QID_test.json",
  "amg_val_json_name": "Split_output_QID_val.json",
  "amg_image_vec_dir": "../AMG_Image_Embedding_File/",
  "amg_text_vec_dir": "../AMG_Text_Embedding_File/",
  "amg_event_vec_dir": "../event_embeddings/",
  "amg_evidence_vec_dir": "./Model/evidence_embeddings/",
  "device": "cuda:3",
  "AKAN_device": "cuda:3",
  "gnn_device": "cuda:3"
}